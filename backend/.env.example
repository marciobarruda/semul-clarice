# ============================================================
# Banco de Dados PostgreSQL (EXTERNO ao GCP)
# ============================================================
DB_HOST=172.21.0.158
DB_PORT=5432
DB_USER=transformacaodigital
DB_PASSWORD=PREENCHA_AQUI
DB_NAME=automacao
DB_SCHEMA=clarice
# DB_SSL=false  # Alterar para true se o servidor exigir SSL

# ============================================================
# Keycloak – OAuth2 Authorization Code Flow
# (Fornecer após configuração do client no Keycloak)
# ============================================================
KC_AUTH_URL=https://login.recife.pe.gov.br/auth/realms/prefeitura/protocol/openid-connect/auth
KC_TOKEN_URL=https://login.recife.pe.gov.br/auth/realms/prefeitura/protocol/openid-connect/token
KC_USERINFO_URL=https://login.recife.pe.gov.br/auth/realms/prefeitura/protocol/openid-connect/userinfo
KC_CLIENT_ID=PREENCHA_AQUI
KC_CLIENT_SECRET=PREENCHA_AQUI
KC_REDIRECT_URI=https://clarice-portal-HASH.southamerica-east1.run.app/

# ============================================================
# Controle de Acesso
# Lista de logins Keycloak (preferred_username) autorizados,
# separados por vírgula. Deixar em branco para permitir
# qualquer usuário autenticado.
# ============================================================
ALLOWED_USERS=

# ============================================================
# Segurança do Cookie de Sessão
# ============================================================
COOKIE_SECRET=troque_por_valor_aleatorio_longo

# ============================================================
# n8n (mantido para Naturalidades e RPA)
# ============================================================
N8N_BASE_URL=https://webhook-n8n-dev-conectarecife.recife.pe.gov.br/webhook

# ============================================================
# Aplicação
# ============================================================
PORT=8080
NODE_ENV=production
